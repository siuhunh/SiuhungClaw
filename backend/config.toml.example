[llm]
# 默认走 DeepSeek（OpenAI 兼容协议）
provider = "deepseek"
# 聊天模型实现类型：deepseek | openai | ollama（未知类型会直接用 ChatDeepSeek；构建失败时回退 ChatDeepSeek）
model_type = "deepseek"
model = "deepseek-chat"
api_key = "your-deepseek-api-key"
base_url = "https://api.deepseek.com/v1"
temperature = 0.2

[embedding]
# RAG 场景下可切到本地 Ollama；未配置时回退到 DeepSeek 配置
provider = "ollama"
model = "nomic-embed-text"
base_url = "http://127.0.0.1:11434"
use_ollama_for_rag = true

[vectordb]
# 启用后，Agent 启动时尝试初始化外部向量库（Milvus）
enabled = false
provider = "milvus"
# uri 与 host/port 二选一；优先 uri
uri = ""
host = "127.0.0.1"
port = "19530"
token = ""
db_name = "default"
# 新部署建议使用带 memory_kind 字段的集合名；旧集合无该字段时会降级为整库检索
collection_name = "aceclaw_memory"
embedding_dim = 1536
top_k = 5
metric_type = "COSINE"

[memory]
# 短期：注入 system prompt 的最近消息条数（user+assistant 各算一条）
short_term_messages = 24
# 是否周期性用 LLM 从对话中抽取长期要点
long_term_enabled = true
# 每累计 N 个 user 轮次触发一次抽取（0 表示关闭周期性抽取）
long_term_every_n_user_turns = 2
# 传给抽取模型的最近消息条数上限
extraction_context_messages = 28
max_long_term_bullets = 80
# Milvus 已启用且集合含 memory_kind 时：长/短向量各取几条
vector_recall_long_k = 4
vector_recall_short_k = 4
